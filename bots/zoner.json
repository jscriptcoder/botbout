{
  "version": 1,
  "name": "zoner",
  "rules": [
    {
      "when": {
        "op": "eq",
        "args": [
          { "op": "field", "path": "self.canAct" },
          { "op": "const", "value": 0 }
        ]
      },
      "do": { "type": "idle" }
    },
    {
      "when": {
        "op": "eq",
        "args": [
          { "op": "field", "path": "opponent.throwing" },
          { "op": "const", "value": 1 }
        ]
      },
      "do": { "type": "throw-break" }
    },
    {
      "when": {
        "op": "lte",
        "args": [
          { "op": "field", "path": "opponent.distance" },
          { "op": "const", "value": 120000 }
        ]
      },
      "do": { "type": "move", "dir": -1 }
    },
    {
      "when": {
        "op": "and",
        "args": [
          {
            "op": "eq",
            "args": [
              { "op": "field", "path": "self.gassed" },
              { "op": "const", "value": 1 }
            ]
          },
          {
            "op": "lte",
            "args": [
              { "op": "field", "path": "opponent.distance" },
              { "op": "const", "value": 240000 }
            ]
          }
        ]
      },
      "do": { "type": "attack", "move": "gyaku-zuki", "band": "mid" }
    },
    {
      "when": {
        "op": "eq",
        "args": [
          { "op": "field", "path": "self.gassed" },
          { "op": "const", "value": 1 }
        ]
      },
      "do": { "type": "move", "dir": -1 }
    },
    {
      "when": {
        "op": "and",
        "args": [
          {
            "op": "lte",
            "args": [
              { "op": "field", "path": "opponent.distance" },
              { "op": "const", "value": 300000 }
            ]
          },
          {
            "op": "gt",
            "args": [
              { "op": "field", "path": "opponent.distance" },
              { "op": "const", "value": 270000 }
            ]
          }
        ]
      },
      "do": { "type": "attack", "move": "mawashi-geri", "band": "high" }
    },
    {
      "when": {
        "op": "and",
        "args": [
          {
            "op": "lte",
            "args": [
              { "op": "field", "path": "opponent.distance" },
              { "op": "const", "value": 270000 }
            ]
          },
          {
            "op": "gt",
            "args": [
              { "op": "field", "path": "opponent.distance" },
              { "op": "const", "value": 240000 }
            ]
          }
        ]
      },
      "do": { "type": "attack", "move": "mae-geri", "band": "mid" }
    },
    {
      "when": {
        "op": "lte",
        "args": [
          { "op": "field", "path": "opponent.distance" },
          { "op": "const", "value": 240000 }
        ]
      },
      "do": { "type": "attack", "move": "gyaku-zuki", "band": "mid" }
    }
  ],
  "default": { "type": "move", "dir": 1 }
}
